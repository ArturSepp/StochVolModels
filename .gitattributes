# normalise line endings: the repository stores LF, Windows checkouts get CRLF
* text=auto
*.py    text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.in    text eol=lf

# binary regression baselines
*.npz   binary
*.pdf   binary
*.png   binary
*.PNG   binary
